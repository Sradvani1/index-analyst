# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SPX_MODEL=claude-opus-4-8
SPX_PROMPT_CACHE_ENABLED=true

# External data is supplied manually in each run's external_context.json
# (US 10Y, forward EPS, and the Fear & Greed index + 7 components, each as
# value + reading). Nothing is fetched over the network.

# Memory / run tuning
SPX_RECENT_STATE_COUNT=5
SPX_IMAGE_MAX_DIMENSION=1568
SPX_MAX_REPORT_CHARS=24000

# Paths (defaults resolve relative to the package root)
# SPX_FRAMEWORK_PATH=framework/SP500-SCHK-Trading-Methodology.md
# SPX_DATA_DIR=data
# SPX_MEMORY_DIR=memory
# SPX_OUTPUT_DIR=output
