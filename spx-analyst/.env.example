# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SPX_MODEL=claude-opus-4-8
SPX_PROMPT_CACHE_ENABLED=true

# EPS master history: data/master/eps_history.json (forward_eps, trailing_eps per effective_from).
# SPX, VIX, and 10Y for precompute are fetched via yfinance at run time.

# Memory / run tuning
SPX_RECENT_STATE_COUNT=6
SPX_IMAGE_MAX_DIMENSION=1568
SPX_PASS2_IMAGE_OPTIMIZATION=true
SPX_PASS2_IMAGE_MAX_DIMENSION=1092
SPX_MAX_REPORT_CHARS=24000
SPX_INCLUDE_MEMORY=false

# Paths (defaults resolve relative to the package root)
# SPX_FRAMEWORK_PATH=framework/SPX-Daily-Analysis-Framework.md
# SPX_ROLE_PATH=framework/SPX-Claude-Role-Block.md
# SPX_DATA_DIR=data
# SPX_EPS_HISTORY_PATH=data/master/eps_history.json
# SPX_MEMORY_DIR=memory
# SPX_OUTPUT_DIR=output
